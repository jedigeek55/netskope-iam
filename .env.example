DATABASE_URL=postgresql://iam:iam_dev_password@localhost/netskope_iam
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SCIM Server — token that Netskope (or any SP) must send when calling /scim/v2/
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SCIM_BEARER_TOKEN=

# Netskope SCIM Client — credentials for reading/writing to your Netskope tenant
# Token location: Netskope Admin > Settings > Tools > Directory Tools > SCIM INTEGRATION > Add Token
NETSKOPE_TENANT=yourtenant.goskope.com
NETSKOPE_SCIM_TOKEN=
NETSKOPE_VERIFY_SSL=true
