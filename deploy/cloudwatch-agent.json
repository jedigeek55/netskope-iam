{
  "agent": {
    "metrics_collection_interval": 60,
    "logfile": "/opt/aws/amazon-cloudwatch-agent/logs/amazon-cloudwatch-agent.log"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/netskope-iam/uvicorn.log",
            "log_group_name": "/netskope-iam/app",
            "log_stream_name": "{instance_id}/uvicorn",
            "timestamp_format": "%Y-%m-%d %H:%M:%S"
          },
          {
            "file_path": "/var/log/netskope-iam/uvicorn-error.log",
            "log_group_name": "/netskope-iam/app",
            "log_stream_name": "{instance_id}/uvicorn-error",
            "timestamp_format": "%Y-%m-%d %H:%M:%S"
          },
          {
            "file_path": "/var/log/nginx/access.log",
            "log_group_name": "/netskope-iam/nginx",
            "log_stream_name": "{instance_id}/access"
          },
          {
            "file_path": "/var/log/nginx/error.log",
            "log_group_name": "/netskope-iam/nginx",
            "log_stream_name": "{instance_id}/error"
          },
          {
            "file_path": "/var/log/iam-setup.log",
            "log_group_name": "/netskope-iam/setup",
            "log_stream_name": "{instance_id}"
          }
        ]
      }
    }
  }
}
